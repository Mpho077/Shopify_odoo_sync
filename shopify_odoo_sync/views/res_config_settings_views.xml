<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_shopify" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.inherit.shopify.auto.invoice</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="sale.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//block[@name='quotation_order_setting_container']" position="after">
                <block title="Shopify Auto-Invoice" name="shopify_auto_invoice_container">
                    <setting id="shopify_auto_create_invoice"
                             string="Auto-Create Invoice"
                             help="Automatically create and post invoices when Shopify orders are confirmed">
                        <field name="shopify_auto_create_invoice"/>
                    </setting>
                    <setting id="shopify_auto_register_payment"
                             string="Auto-Register Payment"
                             help="Automatically register payment for the created invoice"
                             invisible="not shopify_auto_create_invoice">
                        <field name="shopify_auto_register_payment"/>
                        <div class="content-group" invisible="not shopify_auto_register_payment">
                            <div class="mt16">
                                <label for="shopify_payment_journal_id" class="o_light_label"/>
                                <field name="shopify_payment_journal_id" class="oe_inline" required="shopify_auto_register_payment"/>
                            </div>
                        </div>
                    </setting>
                </block>
            </xpath>
        </field>
    </record>

</odoo>
