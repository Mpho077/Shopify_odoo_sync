<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_form_view_shopify" model="ir.ui.view">
        <field name="name">product.template.form.shopify</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Shopify" name="shopify" invisible="not shopify_product_id">
                    <group>
                        <group>
                            <field name="shopify_backend_id" readonly="1"/>
                            <field name="shopify_product_id" readonly="1"/>
                            <field name="shopify_handle" readonly="1"/>
                        </group>
                        <group>
                            <button name="action_sync_from_shopify" type="object" string="Sync from Shopify" class="btn-secondary" icon="fa-refresh"/>
                            <button name="action_view_in_shopify" type="object" string="View in Shopify" class="btn-link" icon="fa-external-link"/>
                        </group>
                    </group>
                    <group string="Sale Description">
                        <field name="description_sale" nolabel="1"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="product_template_list_view_shopify" model="ir.ui.view">
        <field name="name">product.template.list.shopify</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='default_code']" position="after">
                <field name="shopify_synced" string="Shopify" optional="hide"/>
            </xpath>
        </field>
    </record>
</odoo>
