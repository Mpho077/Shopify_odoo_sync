<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="shopify_sync_log_view_list" model="ir.ui.view">
        <field name="name">shopify.sync.log.list</field>
        <field name="model">shopify.sync.log</field>
        <field name="arch" type="xml">
            <list>
                <field name="create_date"/>
                <field name="backend_id"/>
                <field name="sync_type"/>
                <field name="shopify_id"/>
                <field name="status" widget="badge" decoration-success="status == 'success'" decoration-danger="status == 'error'" decoration-warning="status == 'skipped'"/>
                <field name="message"/>
            </list>
        </field>
    </record>

    <record id="shopify_sync_log_view_form" model="ir.ui.view">
        <field name="name">shopify.sync.log.form</field>
        <field name="model">shopify.sync.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="backend_id"/>
                        <field name="sync_type"/>
                        <field name="shopify_id"/>
                        <field name="status"/>
                    </group>
                    <group>
                        <field name="message"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="shopify_sync_log_action" model="ir.actions.act_window">
        <field name="name">Sync Logs</field>
        <field name="res_model">shopify.sync.log</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
