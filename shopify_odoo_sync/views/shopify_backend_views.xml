<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="shopify_backend_view_form" model="ir.ui.view">
        <field name="name">shopify.backend.form</field>
        <field name="model">shopify.backend</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test_connection" type="object" string="Test Connection" class="btn-primary" invisible="state == 'confirmed'"/>
                    <button name="action_sync_all" type="object" string="Sync All" class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_import_products" type="object" string="Import Products" invisible="state != 'confirmed'"/>
                    <button name="action_import_orders" type="object" string="Import Orders" invisible="state != 'confirmed'"/>
                    <button name="action_import_customers" type="object" string="Import Customers" invisible="state != 'confirmed'"/>
                    <button name="action_sync_prices" type="object" string="Sync Prices" invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_logs" type="object" class="oe_stat_button" icon="fa-list">
                            <field name="log_count" widget="statinfo" string="Logs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="Store Name"/></h1>
                    </div>
                    <group>
                        <group string="Connection">
                            <field name="shop_url" placeholder="mystore.myshopify.com"/>
                            <field name="api_key" password="True"/>
                            <field name="webhook_secret" password="True"/>
                            <field name="shopify_location_id"/>
                        </group>
                        <group string="Mapping">
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="warehouse_id"/>
                            <field name="pricelist_id"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Sync Settings" name="sync_settings">
                            <group>
                                <group string="What to Sync">
                                    <field name="sync_products"/>
                                    <field name="sync_orders"/>
                                    <field name="sync_customers"/>
                                    <field name="sync_prices"/>
                                </group>
                                <group string="Order Options">
                                    <field name="auto_confirm_order"/>
                                    <field name="allow_order_updates"/>
                                </group>
                            </group>
                            <group>
                                <group string="Product Fields to Sync">
                                    <field name="sync_product_sku"/>
                                    <field name="sync_product_description"/>
                                    <field name="sync_product_images"/>
                                    <field name="sync_product_weight"/>
                                    <field name="sync_product_barcode"/>
                                </group>
                                <group string="Last Sync Times">
                                    <field name="last_product_sync" readonly="1"/>
                                    <field name="last_order_sync" readonly="1"/>
                                    <field name="last_customer_sync" readonly="1"/>
                                    <field name="last_price_sync" readonly="1"/>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="shopify_backend_view_list" model="ir.ui.view">
        <field name="name">shopify.backend.list</field>
        <field name="model">shopify.backend</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="shop_url"/>
                <field name="state" widget="badge" decoration-success="state == 'confirmed'" decoration-warning="state == 'draft'" decoration-danger="state == 'error'"/>
                <field name="last_product_sync"/>
                <field name="last_order_sync"/>
            </list>
        </field>
    </record>

    <record id="shopify_backend_action" model="ir.actions.act_window">
        <field name="name">Shopify Stores</field>
        <field name="res_model">shopify.backend</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
